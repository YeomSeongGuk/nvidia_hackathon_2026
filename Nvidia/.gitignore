nvidia_shopping.txt

# --- experiments: keep the meta & reports, skip heavy payloads ---
# (individual per-iteration folders can override via `!hypothesis.md` etc.)
experiments/**/output/
experiments/**/pipeline_run/
experiments/**/judge_raw/
experiments/**/*.jsonl
experiments/**/*.jsonl.gz
experiments/**/*.parquet

# --- experiments_stage2: same rules + pin Stage-1 input externally ---
experiments_stage2/**/output/
experiments_stage2/**/pipeline_run/
experiments_stage2/**/judge_raw/
experiments_stage2/**/*.jsonl
experiments_stage2/**/*.jsonl.gz
experiments_stage2/**/*.parquet
experiments_stage2/stage1_pinned/
experiments_stage2/winners/

# --- local notebook checkpoints ---
.ipynb_checkpoints/

